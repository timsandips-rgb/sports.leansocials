rules_version = '2';
service cloud.storage {
  match /b/{bucket}/o {
    match /logos/{communityId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 100 * 1024;
    }
    match /profiles/{userId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 200 * 1024;
    }
  }
}
